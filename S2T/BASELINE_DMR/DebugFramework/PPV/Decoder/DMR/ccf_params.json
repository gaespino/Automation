{
    "_comment": "DMR CCF (Bank 6) decode tables. CCF = CBO + LLC merged (32 CBO instances, 4 ENVs x 8 instances). Source: DMR_CBB_CCF.1.1.html §8.1.2.2.",
    "_note_mscod": "CCF MSCOD is a 16-bit BITMASK — each bit independently signals an error. Multiple bits can be set simultaneously. Use bitmask expansion, not enum lookup.",
    "MSCOD_BITS": [
        "CORRECTABLE_TAG_ERROR",
        "UNCORRECTABLE_TAG_ERROR",
        "CORRECTABLE_DATA_ERROR",
        "UNCORRECTABLE_DATA_ERROR",
        "UNCORRECTABLE_MULTIPLE_TAG_MATCH",
        "MEM_POISON_DATA_ERROR",
        "SAD_ERR_WB_TO_MMIO",
        "RESERVED",
        "SAD_ERR_CORRUPTING_OTHER",
        "SAD_NON_CORRUPTING_ERR_OTHER",
        "MSCOD_DUPLICATE_MAP_ERROR",
        "ADDR_PARITY_ERROR",
        "BE_PARITY_ERROR",
        "DATA_PARITY_ERROR",
        "TOR_TIMEOUT",
        "TOR_RSP_TO_INVALID_ENTRY"
    ],
    "_note_mscod_bits": {
        "bit0": "CORRECTABLE_TAG_ERROR - Correctable Tag/State/CV error (in use in CBB)",
        "bit1": "UNCORRECTABLE_TAG_ERROR - Uncorrectable Tag/State/CV error (reported on eviction or WB miss)",
        "bit2": "CORRECTABLE_DATA_ERROR - Correctable data error",
        "bit3": "UNCORRECTABLE_DATA_ERROR - Uncorrectable data error (double error on data)",
        "bit4": "UNCORRECTABLE_MULTIPLE_TAG_MATCH - Multiple LLC ways reported a tag match simultaneously",
        "bit5": "MEM_POISON_DATA_ERROR - Memory poison data error (non-fatal poison generation or fatal poison handling)",
        "bit6": "SAD_ERR_WB_TO_MMIO - Write back to MMIO space",
        "bit7": "RESERVED - Was SAD_ERR_IA_ACCESS_TO_GSM in v1.0; deprecated in v1.1 (GSM not relevant for server)",
        "bit8": "SAD_ERR_CORRUPTING_OTHER - Specific error in SADError register; can corrupt LLC",
        "bit9": "SAD_NON_CORRUPTING_ERR_OTHER - Specific error in SADError register (non-corrupting)",
        "bit10": "MSCOD_DUPLICATE_MAP_ERROR - Cache had duplicate tag-to-data mappings (cache corruption)",
        "bit11": "ADDR_PARITY_ERROR - Address parity error",
        "bit12": "BE_PARITY_ERROR - Byte enable parity error",
        "bit13": "DATA_PARITY_ERROR - Data parity error",
        "bit14": "TOR_TIMEOUT - UPI TOR timeout (configurable via internal CCF CR)",
        "bit15": "TOR_RSP_TO_INVALID_ENTRY - TOR received a response with invalid TOR ID"
    },
